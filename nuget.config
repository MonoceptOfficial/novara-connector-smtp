<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="novara" value="https://pkgs.dev.azure.com/Novara-Monocept/Workspace/_packaging/workspace/nuget/v3/index.json" />
    <!-- CTO workspace local feed (pre-release SDK builds). Safe to strip before publishing. -->
    <add key="novara-local" value="D:\NovaraDev\LocalNuGet" />
  </packageSources>
  <packageSourceCredentials>
    <novara>
      <add key="Username" value="AzureDevOps" />
      <add key="ClearTextPassword" value="%AZURE_DEVOPS_PAT%" />
    </novara>
  </packageSourceCredentials>
</configuration>
