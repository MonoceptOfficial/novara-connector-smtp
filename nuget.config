<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="novara" value="https://nuget.pkg.github.com/MonoceptOfficial/index.json" />
    <!-- CTO workspace local feed (pre-release SDK builds). Safe to strip before publishing. -->
    <add key="novara-local" value="D:\NovaraDev\LocalNuGet" />
  </packageSources>
  <packageSourceCredentials>
    <novara>
      <add key="Username" value="MonoceptOfficial" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </novara>
  </packageSourceCredentials>
</configuration>
