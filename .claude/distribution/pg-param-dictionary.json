  "_meta": {
    "purpose": "Canonical snake_case splits for compound words used as Novara PostgreSQL function parameter names. Read by .claude/hooks/check-sql-param-naming.py to detect legacy no-underscore forms and by .claude/tools/sweep-module-params.py to generate rename migrations.",
    "rule": ".claude/rules/sql-conventions.md",
    "convention": "Every Novara function parameter is `p_<snake_case>`. Compound words must be split. When adding a novel compound, append an entry here and commit it alongside the new migration.",
    "adopted": "2026-04-22"
  },
